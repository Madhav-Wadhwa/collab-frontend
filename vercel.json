{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://collab-uru2.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://collab-uru2.onrender.com/socket.io/:path*"
    },
    {
      "source": "/((?!api|socket.io).*)/",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|socket.io).*)",
      "destination": "/index.html"
    }
  ]
}
